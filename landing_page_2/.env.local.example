# ──────────────────────────────────────────────────────────
# Supabase credentials (optional — app works without them, but history won't persist)
# Create a project at https://supabase.com and get these from Settings > API
# ──────────────────────────────────────────────────────────

# Server-only (preferred for production — keeps keys out of client bundles)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# Client-exposed fallbacks (used if server-only vars are not set)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ──────────────────────────────────────────────────────────
# Supabase setup:
#
# 1. Create a storage bucket called "diffs" (set to public)
#
# 2. Run this SQL in the SQL editor:
#
#   CREATE TABLE comparisons (
#     id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
#     similarity NUMERIC NOT NULL,
#     diff_image_path TEXT NOT NULL,
#     created_at TIMESTAMPTZ DEFAULT now()
#   );
#
#   ALTER TABLE comparisons ENABLE ROW LEVEL SECURITY;
#   CREATE POLICY "Public read"   ON comparisons FOR SELECT USING (true);
#   CREATE POLICY "Public insert" ON comparisons FOR INSERT WITH CHECK (true);
#
# 3. Add storage RLS policies (in Dashboard > Storage > diffs > Policies):
#
#   CREATE POLICY "Public upload" ON storage.objects FOR INSERT WITH CHECK (bucket_id = 'diffs');
#   CREATE POLICY "Public read"   ON storage.objects FOR SELECT USING (bucket_id = 'diffs');
# ──────────────────────────────────────────────────────────
