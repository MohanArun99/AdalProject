# Supabase credentials (optional — app works without them, but history won't persist)
# Create a project at https://supabase.com and get these from Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase setup:
# 1. Create a storage bucket called "diffs" (set to public)
# 2. Run this SQL in the SQL editor:
#
#   create table comparisons (
#     id uuid primary key default gen_random_uuid(),
#     similarity float not null,
#     diff_image_path text not null,
#     created_at timestamptz not null default now()
#   );
#
#   alter table comparisons enable row level security;
#   create policy "Allow public read" on comparisons for select using (true);
#   create policy "Allow public insert" on comparisons for insert with check (true);
